<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skia="using:Svg.Skia"
             xmlns:vm="using:TestApp.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="TestApp.Views.MainView"
             DragDrop.AllowDrop="True"
             FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid ColumnDefinitions="300,8,*" RowDefinitions="Auto,*,Auto,Auto">

    <TextBox Grid.Column="0"
             Grid.Row="0"
             Margin="6"
             Text="{Binding ItemQuery}"
             PlaceholderText="Filter...">
      <TextBox.InnerRightContent>
        <Button Content="X"
                Command="{Binding ResetQueryCommand}" />
      </TextBox.InnerRightContent>
    </TextBox>

    <ListBox Grid.Column="0"
             Grid.Row="1"
             Margin="6,0,6,0"
             ItemsSource="{Binding FilteredItems}"
             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
             SelectionChanged="SelectingItemsControl_OnSelectionChanged">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="Padding" Value="0" />
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Panel Background="Transparent"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 ToolTip.Tip="{Binding Path}"
                 Focusable="True"
                 DoubleTapped="FileItem_OnDoubleTapped">
            <Panel.KeyBindings>
              <KeyBinding Gesture="Delete" Command="{Binding RemoveCommand}" />
            </Panel.KeyBindings>
            <Panel.ContextFlyout>
              <MenuFlyout Placement="Bottom">
                <MenuItem Header="Open in Explorer" Command="{Binding OpenInExplorerCommand}" />
                <MenuItem Header="Open in Notepad" Command="{Binding OpenInNotepadCommand}" />
                <MenuItem Header="Remove" Command="{Binding RemoveCommand}" />
              </MenuFlyout>
            </Panel.ContextFlyout>
            <TextBlock Text="{Binding Name}"
                       Padding="12"
                       IsHitTestVisible="False" />
          </Panel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <UniformGrid Grid.Column="0"
                 Grid.Row="2"
                 Columns="4">
      <Button Content="Clear"
              Margin="6,6,3,6"
              HorizontalContentAlignment="Center"
              HorizontalAlignment="Stretch"
              Command="{Binding ClearConfigurationCommand}" />
      <Button Content="Save"
              Margin="3,6,3,6"
              HorizontalContentAlignment="Center"
              HorizontalAlignment="Stretch"
              Command="{Binding SaveConfigurationCommand}" />
      <Button Content="Load"
              Margin="3,6,3,6"
              HorizontalContentAlignment="Center"
              HorizontalAlignment="Stretch"
              Command="{Binding LoadConfigurationCommand}" />
      <Button Content="+"
              Margin="3,6,6,6"
              HorizontalContentAlignment="Center"
              HorizontalAlignment="Stretch"
              Command="{Binding AddItemCommand}" />
    </UniformGrid>

    <GridSplitter Grid.Column="1"
                  Grid.Row="0"
                  Grid.RowSpan="3"
                  Background="Transparent" />

    <DockPanel Grid.Column="2"
               Grid.Row="0"
               Grid.RowSpan="3"
               Name="DockPanel"
               Background="Transparent"
               Margin="6"
               VerticalAlignment="Stretch"
               HorizontalAlignment="Stretch">
      <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
          <Label Content="ScrollBar"
                 VerticalAlignment="Center" />
          <Label Content="H:"
                 Margin="6,0,6,0"
                 VerticalAlignment="Center" />
          <ComboBox Name="HorizontalScrollBarVisibility"
                    Width="120"
                    SelectedIndex="0">
            <ScrollBarVisibility>Disabled</ScrollBarVisibility>
            <ScrollBarVisibility>Auto</ScrollBarVisibility>
            <ScrollBarVisibility>Hidden</ScrollBarVisibility>
            <ScrollBarVisibility>Visible</ScrollBarVisibility>
          </ComboBox>
          <Label Content="V:"
                 Margin="6,0,6,0"
                 VerticalAlignment="Center" />
          <ComboBox Name="VerticalScrollBarVisibility"
                    Width="120"
                    SelectedIndex="0">
            <ScrollBarVisibility>Disabled</ScrollBarVisibility>
            <ScrollBarVisibility>Auto</ScrollBarVisibility>
            <ScrollBarVisibility>Hidden</ScrollBarVisibility>
            <ScrollBarVisibility>Visible</ScrollBarVisibility>
          </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
          <Label Content="Stretch:"
                 Margin="0,0,6,0"
                 VerticalAlignment="Center" />
          <ComboBox Name="SvgStretch"
                    Width="140"
                    SelectedIndex="0">
            <Stretch>None</Stretch>
            <Stretch>Fill</Stretch>
            <Stretch>Uniform</Stretch>
            <Stretch>UniformToFill</Stretch>
          </ComboBox>
        </StackPanel>

        <ToggleSwitch IsChecked="{Binding #Svg.EnableCache}"
                      OnContent="Cache Enabled"
                      OffContent="Cache Disabled"
                      Margin="0,0,12,6" />
        <ToggleSwitch Name="ShowHitBoundsToggle"
                      IsChecked="{Binding SvgView.ShowHitBounds, Mode=TwoWay}"
                      OnContent="Show Bounds"
                      OffContent="Hide Bounds"
                      Margin="0,0,12,6" />
        <ToggleSwitch IsChecked="{Binding #Svg.Wireframe}"
                      OnContent="Wireframe On"
                      OffContent="Wireframe Off"
                      Margin="0,0,12,6" />

        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
          <Label Content="Anim:"
                 Margin="0,0,6,0"
                 VerticalAlignment="Center" />
          <ComboBox Name="AnimationBackendBox"
                    Width="140"
                    SelectedItem="{Binding #Svg.AnimationBackend, Mode=TwoWay}">
            <skia:SvgAnimationHostBackend>Default</skia:SvgAnimationHostBackend>
            <skia:SvgAnimationHostBackend>Manual</skia:SvgAnimationHostBackend>
            <skia:SvgAnimationHostBackend>DispatcherTimer</skia:SvgAnimationHostBackend>
            <skia:SvgAnimationHostBackend>RenderLoop</skia:SvgAnimationHostBackend>
            <skia:SvgAnimationHostBackend>NativeComposition</skia:SvgAnimationHostBackend>
          </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
          <Label Content="Rate:"
                 Margin="0,0,6,0"
                 VerticalAlignment="Center" />
          <Slider Name="AnimationPlaybackRateSlider"
                  Width="120"
                  Minimum="0"
                  Maximum="4"
                  Value="{Binding #Svg.AnimationPlaybackRate, Mode=TwoWay}" />
          <TextBlock Margin="6,0,0,0"
                     VerticalAlignment="Center"
                     Text="{Binding #Svg.AnimationPlaybackRate, StringFormat={}{0:0.00}x}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
          <Button Name="PlayAnimationButton"
                  Content="Play"
                  IsEnabled="{Binding SvgView.CanPlay}"
                  Click="PlayAnimationButton_OnClick" />
          <Button Name="PauseAnimationButton"
                  Content="Pause"
                  Margin="6,0,0,0"
                  IsEnabled="{Binding SvgView.CanPause}"
                  Click="PauseAnimationButton_OnClick" />
          <Button Name="RestartAnimationButton"
                  Content="Restart"
                  Margin="6,0,0,0"
                  IsEnabled="{Binding SvgView.CanRestart}"
                  Click="RestartAnimationButton_OnClick" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
          <TextBlock VerticalAlignment="Center"
                     Text="{Binding SvgView.AnimationStatusText}" />
          <TextBlock Margin="6,0,0,0"
                     VerticalAlignment="Center"
                     Text="|" />
          <TextBlock Margin="6,0,0,0"
                     VerticalAlignment="Center"
                     Text="{Binding SvgView.AnimationClockText}" />
        </StackPanel>

        <TextBlock Margin="0,0,12,6"
                   VerticalAlignment="Center"
                   Text="{Binding SvgView.AnimationBackendInfoText}"
                   ToolTip.Tip="{Binding SvgView.AnimationBackendFallbackReason}" />

        <Button Content="Export"
                Margin="0,0,0,6"
                Click="ExportButton_OnClick" />
      </WrapPanel>
      <ScrollViewer HorizontalScrollBarVisibility="{Binding #HorizontalScrollBarVisibility.SelectedItem}"
                    VerticalScrollBarVisibility="{Binding #VerticalScrollBarVisibility.SelectedItem}">
        <ScrollViewer.ContextFlyout>
          <MenuFlyout Placement="Bottom">
            <MenuItem Header="Export"
                      Click="ExportButton_OnClick" />
          </MenuFlyout>
        </ScrollViewer.ContextFlyout>
        <Svg Name="Svg"
             Stretch="{Binding #SvgStretch.SelectedItem}"
             Path="{Binding SelectedItem.Path, FallbackValue=''}"
             EnableCache="True"
             AnimationBackend="Default"
             PointerPressed="Svg_OnPointerPressed" />
      </ScrollViewer>
    </DockPanel>

    <ListBox Grid.Column="2"
             Grid.Row="3"
             Margin="6"
             ItemsSource="{Binding SvgView.HitResults}" />

  </Grid>

</UserControl>
