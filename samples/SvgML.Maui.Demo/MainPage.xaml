<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SvgML.Maui.Demo.MainPage"
             Title="Bound Fill">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="SvgML.Maui"
                   FontSize="28"
                   FontAttributes="Bold" />
            <Label Text="Bind standard .NET MAUI controls into inline SvgML properties."
                   LineBreakMode="WordWrap" />

            <Border Padding="18"
                    Stroke="#330F172A"
                    StrokeThickness="1"
                    BackgroundColor="#FCFCFD">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Inline SVG with Bound Fill"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <ContentView x:Name="BoundSvgHost" />

                    <Entry x:Name="CircleFill"
                           Placeholder="Circle fill"
                           Text="tomato" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
