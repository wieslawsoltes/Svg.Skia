<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SvgML.Maui.Demo.InlineControlsPage"
             Title="Hosted Controls">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="foreignObject controls inside SvgML"
                   FontSize="28"
                   FontAttributes="Bold" />
            <Label Text="SVG foreignObject reserves text layout inside the SVG and hosts a real .NET MAUI control there, so the controls stay part of the text flow instead of being manually overlaid."
                   LineBreakMode="WordWrap" />

            <Border Padding="18"
                    Stroke="#330F172A"
                    StrokeThickness="1"
                    BackgroundColor="#FCFCFD">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Inline foreignObject controls arranged on SVG text rows"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <ContentView x:Name="HostedSvgHost" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
