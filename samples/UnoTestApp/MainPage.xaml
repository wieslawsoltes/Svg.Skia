<Page x:Class="UnoTestApp.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:svg="using:Uno.Svg.Skia"
      xmlns:vm="using:TestApp.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Grid AllowDrop="True"
        DragOver="Root_OnDragOver"
        Drop="Root_OnDrop">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="300" />
      <ColumnDefinition Width="8" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Column="0" Grid.Row="0" Margin="6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBox Grid.Column="0"
               Text="{Binding ItemQuery, Mode=TwoWay}"
               PlaceholderText="Filter..." />
      <Button Grid.Column="1"
              Margin="6,0,0,0"
              Content="X"
              Command="{Binding ResetQueryCommand}" />
    </Grid>

    <ListView x:Name="FileList"
              Grid.Column="0"
              Grid.Row="1"
              Margin="6,0,6,0"
              ItemsSource="{Binding FilteredItems}"
              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
              IsItemClickEnabled="False"
              SelectionChanged="FileList_OnSelectionChanged"
              KeyDown="FileList_OnKeyDown">
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:FileItemViewModel">
          <Grid Padding="12"
                Background="Transparent"
                DoubleTapped="FileItem_OnDoubleTapped"
                ToolTipService.ToolTip="{Binding Path}">
            <Grid.ContextFlyout>
              <MenuFlyout>
                <MenuFlyoutItem Text="Open in Explorer" Command="{Binding OpenInExplorerCommand}" />
                <MenuFlyoutItem Text="Open in Notepad" Command="{Binding OpenInNotepadCommand}" />
                <MenuFlyoutItem Text="Remove" Command="{Binding RemoveCommand}" />
              </MenuFlyout>
            </Grid.ContextFlyout>
            <TextBlock Text="{Binding Name}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <Grid Grid.Column="0" Grid.Row="2" Margin="6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Margin="0,0,3,0" Content="Clear" Command="{Binding ClearConfigurationCommand}" />
      <Button Grid.Column="1" Margin="3,0,3,0" Content="Save" Command="{Binding SaveConfigurationCommand}" />
      <Button Grid.Column="2" Margin="3,0,3,0" Content="Load" Command="{Binding LoadConfigurationCommand}" />
      <Button Grid.Column="3" Margin="3,0,0,0" Content="+" Command="{Binding AddItemCommand}" />
    </Grid>

    <Border Grid.Column="1"
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="Transparent" />

    <Grid Grid.Column="2"
          Grid.Row="0"
          Grid.RowSpan="3"
          Margin="6">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,6">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="ScrollBar" VerticalAlignment="Center" />
            <TextBlock Text="H:" VerticalAlignment="Center" />
            <ComboBox x:Name="HorizontalScrollBarVisibilityBox"
                      Width="120"
                      SelectionChanged="HorizontalScrollBarVisibilityBox_OnSelectionChanged" />
            <TextBlock Text="V:" VerticalAlignment="Center" />
            <ComboBox x:Name="VerticalScrollBarVisibilityBox"
                      Width="120"
                      SelectionChanged="VerticalScrollBarVisibilityBox_OnSelectionChanged" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Stretch:" VerticalAlignment="Center" />
            <ComboBox x:Name="SvgStretchBox"
                      Width="140"
                      SelectionChanged="SvgStretchBox_OnSelectionChanged" />
          </StackPanel>

          <ToggleSwitch x:Name="EnableCacheToggle"
                        Header="Cache Enabled"
                        Toggled="EnableCacheToggle_OnToggled" />
          <ToggleSwitch Header="Show Bounds"
                        IsOn="{Binding SvgView.ShowHitBounds, Mode=TwoWay}" />
          <ToggleSwitch x:Name="WireframeToggle"
                        Header="Wireframe On"
                        Toggled="WireframeToggle_OnToggled" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Anim:" VerticalAlignment="Center" />
            <ComboBox x:Name="AnimationBackendBox"
                      Width="140"
                      SelectionChanged="AnimationBackendBox_OnSelectionChanged" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Rate:" VerticalAlignment="Center" />
            <Slider x:Name="AnimationPlaybackRateSlider"
                    Width="120"
                    Minimum="0"
                    Maximum="4"
                    ValueChanged="AnimationPlaybackRateSlider_OnValueChanged" />
            <TextBlock x:Name="AnimationPlaybackRateText"
                       VerticalAlignment="Center"
                       Text="1.00x" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Content="Play"
                    IsEnabled="{Binding SvgView.CanPlay}"
                    Click="PlayAnimationButton_OnClick" />
            <Button Content="Pause"
                    IsEnabled="{Binding SvgView.CanPause}"
                    Click="PauseAnimationButton_OnClick" />
            <Button Content="Restart"
                    IsEnabled="{Binding SvgView.CanRestart}"
                    Click="RestartAnimationButton_OnClick" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding SvgView.AnimationStatusText}" />
            <TextBlock VerticalAlignment="Center" Text="|" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding SvgView.AnimationClockText}" />
          </StackPanel>

          <TextBlock VerticalAlignment="Center"
                     Text="{Binding SvgView.AnimationBackendInfoText}"
                     ToolTipService.ToolTip="{Binding SvgView.AnimationBackendFallbackReason}" />

          <Button Content="Export"
                  Click="ExportButton_OnClick" />
        </StackPanel>
      </StackPanel>

      <ScrollViewer x:Name="SvgScrollViewer"
                    Grid.Row="1">
        <ScrollViewer.ContextFlyout>
          <MenuFlyout>
            <MenuFlyoutItem Text="Export" Click="ExportButton_OnClick" />
          </MenuFlyout>
        </ScrollViewer.ContextFlyout>
        <svg:Svg x:Name="Svg"
                 Path="{Binding SelectedItem.Path, FallbackValue=''}"
                 Stretch="None"
                 EnableCache="True"
                 AnimationBackend="Default"
                 PointerPressed="Svg_OnPointerPressed" />
      </ScrollViewer>
    </Grid>

    <ListView Grid.Column="2"
              Grid.Row="3"
              Margin="6"
              ItemsSource="{Binding SvgView.HitResults}" />
  </Grid>
</Page>
