<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <EnableDefaultCompileItems>False</EnableDefaultCompileItems>
    <EnableDefaultItems>False</EnableDefaultItems>
    <IsPackable>True</IsPackable>
    <Nullable>enable</Nullable>
    <RootNamespace>Svg.Editor.Skia.Avalonia</RootNamespace>
  </PropertyGroup>

  <PropertyGroup>
    <Description>Interactive Avalonia surface and workspace composition for the SVG editor stack.</Description>
    <PackageId>Svg.Editor.Skia.Avalonia</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>svg;editor;avalonia;skia;surface;workspace</PackageTags>
  </PropertyGroup>

  <Import Project="..\..\build\SourceLink.props" />
  <Import Project="..\..\build\SignAssembly.props" />
  <Import Project="..\..\build\ReferenceAssemblies.props" />
  <Import Project="..\..\build\Avalonia.props" />
  <Import Project="..\..\build\Avalonia.Skia.props" />

  <ItemGroup>
    <ProjectReference Include="..\Svg.Editor.Avalonia\Svg.Editor.Avalonia.csproj" />
    <ProjectReference Include="..\Svg.Editor.Core\Svg.Editor.Core.csproj" />
    <ProjectReference Include="..\Svg.Editor.Skia\Svg.Editor.Skia.csproj" />
    <ProjectReference Include="..\Svg.Editor.Svg\Svg.Editor.Svg.csproj" />
    <ProjectReference Include="..\Svg.Controls.Skia.Avalonia\Svg.Controls.Skia.Avalonia.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Controls.DataGrid" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="obj\**" />
    <AvaloniaXaml Include="**\*.axaml" Exclude="obj\**" />
  </ItemGroup>

</Project>
