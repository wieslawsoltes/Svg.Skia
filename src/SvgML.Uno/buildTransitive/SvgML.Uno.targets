<Project>
  <UsingTask TaskName="SvgMLTransformUnoXaml"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Sources ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <ProjectDirectory ParameterType="System.String" Required="true" />
      <IntermediateOutputPath ParameterType="System.String" Required="true" />
      <GeneratedPages ParameterType="Microsoft.Build.Framework.ITaskItem[]" Output="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="Microsoft.Build.Framework" />
      <Using Namespace="Microsoft.Build.Utilities" />
      <Using Namespace="System.Xml.Linq" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        var generatedPages = new List<ITaskItem>();
        var projectDirectory = Path.GetFullPath(ProjectDirectory);
        var intermediatePath = Path.IsPathRooted(IntermediateOutputPath)
            ? IntermediateOutputPath
            : Path.Combine(projectDirectory, IntermediateOutputPath);
        var outputRoot = Path.Combine(intermediatePath, "SvgML.Uno.Xaml");
        Directory.CreateDirectory(outputRoot);

        foreach (var source in Sources)
        {
            var sourcePath = source.GetMetadata("FullPath");
            if (string.IsNullOrWhiteSpace(sourcePath))
            {
                sourcePath = source.ItemSpec;
            }

            sourcePath = GetFullPath(sourcePath, projectDirectory);
            var relativePath = GetRelativePath(projectDirectory, sourcePath);
            if (relativePath.StartsWith("..", StringComparison.Ordinal) || Path.IsPathRooted(relativePath))
            {
                relativePath = Path.GetFileName(sourcePath);
            }

            var outputPath = Path.Combine(outputRoot, relativePath);
            Directory.CreateDirectory(Path.GetDirectoryName(outputPath)!);

            var original = File.ReadAllText(sourcePath);
            var transformed = TransformSvgMLTextContent(original, out var changed);
            if (!changed)
            {
                continue;
            }

            File.WriteAllText(outputPath, transformed);

            var generated = new TaskItem(outputPath);
            source.CopyMetadataTo(generated);
            generated.SetMetadata("OriginalItemSpec", source.ItemSpec);
            generated.SetMetadata("Link", string.IsNullOrWhiteSpace(source.GetMetadata("Link")) ? relativePath : source.GetMetadata("Link"));
            generatedPages.Add(generated);
        }

        GeneratedPages = generatedPages.ToArray();

        static string TransformSvgMLTextContent(string xaml, out bool changed)
        {
            var document = XDocument.Parse(xaml, LoadOptions.PreserveWhitespace);
            var svgNamespace = XNamespace.Get("using:SvgML");
            changed = false;

            if (!document.Descendants()
                .Where(element => element.Name.Namespace == svgNamespace)
                .SelectMany(element => element.Nodes())
                .OfType<XText>()
                .Any(text => !string.IsNullOrWhiteSpace(text.Value)))
            {
                return xaml;
            }

            foreach (var element in document.Descendants().Where(element => element.Name.Namespace == svgNamespace).ToList())
            {
                foreach (var node in element.Nodes().ToList())
                {
                    switch (node)
                    {
                        case XText text when string.IsNullOrWhiteSpace(text.Value):
                            text.Remove();
                            changed = true;
                            break;

                        case XText text:
                            text.ReplaceWith(new XElement(svgNamespace + "content", new XAttribute("Content", text.Value)));
                            changed = true;
                            break;
                    }
                }
            }

            if (!changed)
            {
                return xaml;
            }

            using var writer = new StringWriter();
            document.Save(writer, SaveOptions.DisableFormatting);
            return writer.ToString();
        }

        static string GetFullPath(string path, string basePath)
        {
            return Path.GetFullPath(Path.IsPathRooted(path) ? path : Path.Combine(basePath, path));
        }

        static string GetRelativePath(string basePath, string path)
        {
            var baseUri = new Uri(AppendDirectorySeparator(Path.GetFullPath(basePath)));
            var pathUri = new Uri(Path.GetFullPath(path));
            var relativeUri = baseUri.MakeRelativeUri(pathUri);
            return Uri.UnescapeDataString(relativeUri.ToString()).Replace('/', Path.DirectorySeparatorChar);
        }

        static string AppendDirectorySeparator(string path)
        {
            return path.EndsWith(Path.DirectorySeparatorChar.ToString(), StringComparison.Ordinal)
                ? path
                : path + Path.DirectorySeparatorChar;
        }
      ]]></Code>
    </Task>
  </UsingTask>

  <Target Name="SvgML_TransformUnoXaml"
          BeforeTargets="_InjectAdditionalFiles;GenerateMSBuildEditorConfigFileShouldRun;GenerateMSBuildEditorConfigFileCore;CoreCompile"
          Condition="'$(SvgMLUnoTransformXaml)' != 'false' and '@(Page)' != ''">
    <ItemGroup>
      <_SvgMLUnoXamlPage Include="@(Page)"
                         Condition="'%(Extension)' == '.xaml' and Exists('%(FullPath)')" />
    </ItemGroup>

    <SvgMLTransformUnoXaml Sources="@(_SvgMLUnoXamlPage)"
                           ProjectDirectory="$(MSBuildProjectDirectory)"
                           IntermediateOutputPath="$(IntermediateOutputPath)">
      <Output TaskParameter="GeneratedPages" ItemName="_SvgMLUnoGeneratedPage" />
    </SvgMLTransformUnoXaml>

    <ItemGroup>
      <Page Remove="@(_SvgMLUnoGeneratedPage->'%(OriginalItemSpec)')" />
      <Page Include="@(_SvgMLUnoGeneratedPage)" Condition="'@(_SvgMLUnoGeneratedPage)' != ''" />
    </ItemGroup>
  </Target>
</Project>
