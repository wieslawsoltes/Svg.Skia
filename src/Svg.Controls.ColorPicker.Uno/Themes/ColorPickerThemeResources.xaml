<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Svg.Controls.ColorPicker.Uno.Converters">

  <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />

  <SolidColorBrush x:Key="TextBrush" Color="#111827" />
  <SolidColorBrush x:Key="SubtleTextBrush" Color="#475467" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="#98A2B3" />
  <SolidColorBrush x:Key="SurfaceStrokeBrush" Color="#D0D5DD" />
  <SolidColorBrush x:Key="FieldSurfaceBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="FieldBorderBrush" Color="#D0D5DD" />
  <SolidColorBrush x:Key="PickerSurfaceBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="PickerSectionBrush" Color="#F8FAFC" />
  <SolidColorBrush x:Key="PickerChipBrush" Color="#F2F4F7" />
  <SolidColorBrush x:Key="PickerDividerBrush" Color="#E4E7EC" />
  <SolidColorBrush x:Key="PickerShadowBrush" Color="#22000000" />

  <Style x:Key="ShellTitleStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13.25" />
  </Style>

  <Style x:Key="ShellBodyStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
    <Setter Property="FontSize" Value="12.25" />
  </Style>

  <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
    <Setter Property="FontSize" Value="11.5" />
  </Style>

  <Style x:Key="PickerHeaderButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinWidth" Value="96" />
  </Style>

  <Style x:Key="PickerIconButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource PickerChipBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource PickerDividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Width" Value="38" />
    <Setter Property="Height" Value="38" />
  </Style>

  <Style x:Key="PickerInlineTextBoxStyle" TargetType="TextBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style x:Key="PickerTextBoxStyle" TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="42" />
  </Style>

  <Style x:Key="PickerComboBoxStyle" TargetType="ComboBox">
    <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinWidth" Value="96" />
  </Style>

  <Style x:Key="PickerFlyoutPresenterStyle" TargetType="FlyoutPresenter">
    <Setter Property="Background" Value="{StaticResource PickerSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource PickerDividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style x:Key="PickerMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
    <Setter Property="Background" Value="{StaticResource PickerSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource PickerDividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="4" />
  </Style>
</ResourceDictionary>
