<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Thickness x:Key="ShellOuterMargin">12</Thickness>
  <Thickness x:Key="ShellTopBarMargin">14,10,14,4</Thickness>
