<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.SvgEditorCommentsLayer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid>
    <Canvas x:Name="PinsCanvas" />

    <Border x:Name="ComposerBorder"
            Visibility="Collapsed"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Style="{StaticResource FloatingTrayBorderStyle}"
            Background="{StaticResource SurfaceBrush}"
            Padding="8,8,8,8">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
            ColumnSpacing="8"
            MinWidth="364">
        <Border Width="30"
                Height="30"
                Background="{StaticResource AccentBrush}"
                CornerRadius="15"
                VerticalAlignment="Center">
          <controls:FigmaIcon Kind="Comment"
                              Width="15"
                              Height="15"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              IconStroke="White" />
        </Border>

        <TextBox x:Name="ComposerTextBox"
                 Grid.Column="1"
                 Style="{StaticResource SearchFieldTextBoxStyle}"
                 PlaceholderText="Add a comment"
                 Text="{Binding ComposerText, ElementName=Root, Mode=TwoWay}"
                 TextChanged="OnComposerTextChanged"
                 KeyDown="OnComposerKeyDown"
                 MinWidth="220"
                 VerticalContentAlignment="Center" />

        <Button Grid.Column="2"
                Style="{StaticResource SubtleIconButtonStyle}"
                Click="OnCancelClick">
          <controls:FigmaIcon Kind="Close"
                              Width="14"
                              Height="14"
                              IconStroke="{StaticResource MutedTextBrush}" />
        </Button>

        <Border Grid.Column="3"
                Background="{StaticResource AccentBrush}"
                CornerRadius="16">
          <Button Style="{StaticResource ToolButtonStyle}"
                  Padding="8"
                  Click="OnSubmitClick">
            <controls:FigmaIcon Kind="Send"
                                Width="14"
                                Height="14"
                                IconStroke="White" />
          </Button>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
