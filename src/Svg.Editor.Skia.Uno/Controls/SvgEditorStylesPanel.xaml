<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.SvgEditorStylesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    xmlns:models="using:Svg.Editor.Skia.Uno.Models"
    xmlns:pickerModels="using:Svg.Controls.ColorPicker.Uno.Models"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <Style x:Key="StyleRowButtonStyle"
             TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      </Style>
    </ResourceDictionary>
  </UserControl.Resources>

  <StackPanel Spacing="18">
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="Styles"
                 Style="{StaticResource ShellTitleStyle}"
                 FontSize="14" />
      <Button Grid.Column="1"
              Style="{StaticResource InspectorSectionActionButtonStyle}">
        <Button.Flyout>
          <MenuFlyout>
            <MenuFlyoutItem Text="Text"
                            Tag="Text"
                            Click="OnCreateStyleMenuItemClick" />
            <MenuFlyoutItem Text="Color"
                            Tag="Color"
                            Click="OnCreateStyleMenuItemClick" />
            <MenuFlyoutItem Text="Effect"
                            Tag="Effect"
                            Click="OnCreateStyleMenuItemClick" />
            <MenuFlyoutItem Text="Layout guide"
                            Tag="LayoutGuide"
                            Click="OnCreateStyleMenuItemClick" />
          </MenuFlyout>
        </Button.Flyout>
        <controls:FigmaIcon Kind="Add"
                            Width="14"
                            Height="14"
                            IconStroke="{StaticResource TextBrush}" />
      </Button>
    </Grid>

    <StackPanel Spacing="10">
      <TextBlock Text="Text styles"
                 Style="{StaticResource SectionCaptionStyle}" />
      <ItemsControl ItemsSource="{Binding TextStyles, ElementName=Root, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:EditorTextStyleItem">
            <Grid Margin="0,0,0,8"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <Button Style="{StaticResource StyleRowButtonStyle}"
                      Click="OnTextStyleApplyClick">
                <Border Background="{StaticResource PickerChipBrush}"
                        BorderBrush="{StaticResource PickerDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,8">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="10">
                    <TextBlock Text="{x:Bind PreviewText}"
                               Style="{StaticResource ShellTitleStyle}"
                               FontSize="22"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                      <TextBlock Text="{x:Bind Name}"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                      <TextBlock Text="{x:Bind Summary}"
                                 Style="{StaticResource SectionCaptionStyle}"
                                 FontSize="11" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
              <Button Grid.Column="1"
                      Style="{StaticResource InspectorSectionActionButtonStyle}"
                      Click="OnTextStyleEditClick">
                <controls:FigmaIcon Kind="Adjust"
                                    Width="14"
                                    Height="14"
                                    IconStroke="{StaticResource TextBrush}" />
              </Button>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Spacing="10">
      <TextBlock Text="Color styles"
                 Style="{StaticResource SectionCaptionStyle}" />
      <ItemsControl ItemsSource="{Binding ColorStyles, ElementName=Root, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="pickerModels:ColorSwatchItem">
            <Grid Margin="0,0,0,8"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <Button Style="{StaticResource StyleRowButtonStyle}"
                      Click="OnColorStyleApplyClick">
                <Border Background="{StaticResource PickerChipBrush}"
                        BorderBrush="{StaticResource PickerDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,8">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="10">
                    <Ellipse Width="18"
                             Height="18"
                             Fill="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" />
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                      <TextBlock Text="{x:Bind Label}"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                      <TextBlock Text="{x:Bind StyleSummary}"
                                 Style="{StaticResource SectionCaptionStyle}"
                                 FontSize="11" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
              <Button Grid.Column="1"
                      Style="{StaticResource InspectorSectionActionButtonStyle}"
                      Click="OnColorStyleEditClick">
                <controls:FigmaIcon Kind="Adjust"
                                    Width="14"
                                    Height="14"
                                    IconStroke="{StaticResource TextBrush}" />
              </Button>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Spacing="10">
      <TextBlock Text="Effect styles"
                 Style="{StaticResource SectionCaptionStyle}" />
      <ItemsControl ItemsSource="{Binding EffectStyles, ElementName=Root, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:EditorEffectStyleItem">
            <Grid Margin="0,0,0,8"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <Button Style="{StaticResource StyleRowButtonStyle}"
                      Click="OnEffectStyleApplyClick">
                <Border Background="{StaticResource PickerChipBrush}"
                        BorderBrush="{StaticResource PickerDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,8">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="10">
                    <controls:FigmaIcon Kind="Adjust"
                                        Width="18"
                                        Height="18"
                                        IconStroke="{StaticResource TextBrush}"
                                        VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                      <TextBlock Text="{x:Bind Name}"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                      <TextBlock Text="{x:Bind Summary}"
                                 Style="{StaticResource SectionCaptionStyle}"
                                 FontSize="11" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
              <Button Grid.Column="1"
                      Style="{StaticResource InspectorSectionActionButtonStyle}"
                      Click="OnEffectStyleEditClick">
                <controls:FigmaIcon Kind="Adjust"
                                    Width="14"
                                    Height="14"
                                    IconStroke="{StaticResource TextBrush}" />
              </Button>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Spacing="10">
      <TextBlock Text="Layout guide styles"
                 Style="{StaticResource SectionCaptionStyle}" />
      <ItemsControl ItemsSource="{Binding LayoutGuideStyles, ElementName=Root, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:EditorLayoutGuideStyleItem">
            <Grid Margin="0,0,0,8"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <Button Style="{StaticResource StyleRowButtonStyle}"
                      Click="OnLayoutGuideStyleApplyClick">
                <Border Background="{StaticResource PickerChipBrush}"
                        BorderBrush="{StaticResource PickerDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,8">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="10">
                    <controls:FigmaIcon Kind="AutoLayoutGrid"
                                        Width="18"
                                        Height="18"
                                        IconStroke="{StaticResource TextBrush}"
                                        VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                      <TextBlock Text="{x:Bind Name}"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                      <TextBlock Text="{x:Bind Summary}"
                                 Style="{StaticResource SectionCaptionStyle}"
                                 FontSize="11" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
              <Button Grid.Column="1"
                      Style="{StaticResource InspectorSectionActionButtonStyle}"
                      Click="OnLayoutGuideStyleEditClick">
                <controls:FigmaIcon Kind="Adjust"
                                    Width="14"
                                    Height="14"
                                    IconStroke="{StaticResource TextBrush}" />
              </Button>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </StackPanel>
</UserControl>
