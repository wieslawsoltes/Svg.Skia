<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.SvgEditorUtilityRail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Border Style="{StaticResource TopBarIslandBorderStyle}"
          Padding="6,10">
    <Grid RowDefinitions="Auto,*,Auto">
      <Button Style="{StaticResource RailIconButtonStyle}"
              Background="{StaticResource AccentSoftBrush}"
              BorderBrush="{StaticResource AccentStrongBrush}"
              Foreground="{StaticResource AccentBrush}"
              HorizontalAlignment="Center"
              Click="OnMainMenuClick"
              ToolTipService.ToolTip="Open file and canvas actions">
        <controls:FigmaIcon Kind="Menu"
                            Width="16"
                            Height="16"
                            IconStroke="{StaticResource AccentBrush}" />
      </Button>

      <StackPanel Grid.Row="1"
                  Margin="0,18,0,18"
                  Spacing="8"
                  VerticalAlignment="Top">
        <Button Style="{StaticResource RailIconButtonStyle}"
                Background="{StaticResource AccentSoftBrush}"
                BorderBrush="{StaticResource AccentStrongBrush}"
                Foreground="{StaticResource AccentBrush}"
                Click="OnLeftPanelToggleClick"
                ToolTipService.ToolTip="Collapse left navigation">
          <Grid Width="16"
                Height="12">
            <Border Width="5"
                    Height="12"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1.1"
                    CornerRadius="2"
                    HorizontalAlignment="Left" />
            <Border Width="8"
                    Height="12"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1.1"
                    CornerRadius="2"
                    HorizontalAlignment="Right" />
          </Grid>
        </Button>

        <Border Background="{Binding ViewModel.IsLayersViewActive, ElementName=Root, Mode=OneWay, Converter={StaticResource BooleanToSidebarTabBrushConverter}}"
                CornerRadius="12">
          <Button Style="{StaticResource RailIconButtonStyle}"
                  Click="OnLayersClick"
                  ToolTipService.ToolTip="Show pages and layers">
            <controls:FigmaIcon Kind="Page"
                                Width="14"
                                Height="14"
                                IconStroke="{StaticResource TextBrush}" />
          </Button>
        </Border>

        <Border Background="{Binding ViewModel.IsAssetsViewActive, ElementName=Root, Mode=OneWay, Converter={StaticResource BooleanToSidebarTabBrushConverter}}"
                CornerRadius="12">
          <Button Style="{StaticResource RailIconButtonStyle}"
                  Click="OnAssetsClick"
                  ToolTipService.ToolTip="Show assets and libraries">
            <controls:FigmaIcon Kind="Library"
                                Width="14"
                                Height="14"
                                IconStroke="{StaticResource TextBrush}" />
          </Button>
        </Border>
      </StackPanel>

      <Button Grid.Row="2"
              Style="{StaticResource RailIconButtonStyle}"
              HorizontalAlignment="Center"
              Click="OnActionsClick"
              ToolTipService.ToolTip="Open quick actions">
        <controls:FigmaIcon Kind="Actions"
                            Width="15"
                            Height="15"
                            IconStroke="{StaticResource TextBrush}" />
      </Button>
    </Grid>
  </Border>
</UserControl>
