<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.FigmaLibrariesManager"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    xmlns:models="using:Svg.Editor.Skia.Uno.Models"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Border Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource SurfaceStrokeBrush}"
          BorderThickness="1"
          CornerRadius="22">
    <Grid RowDefinitions="Auto,*">
      <Grid Padding="30,24,22,20"
            ColumnDefinitions="*,Auto">
        <TextBlock Text="Manage libraries"
                   Style="{StaticResource ShellTitleStyle}"
                   FontSize="18" />

        <Button Grid.Column="1"
                Style="{StaticResource ChromeButtonStyle}"
                Padding="8"
                Click="OnCloseClick">
          <controls:FigmaIcon Kind="Close"
                              Width="18"
                              Height="18"
                              IconStroke="{StaticResource TextBrush}" />
        </Button>
      </Grid>

      <Border Grid.Row="1"
              BorderBrush="{StaticResource SurfaceStrokeBrush}"
              BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="248,*">
          <Border BorderBrush="{StaticResource SurfaceStrokeBrush}"
                  BorderThickness="0,0,1,0">
            <StackPanel Padding="16"
                        Spacing="18">
              <controls:EditorSearchField x:Name="SearchTextBox"
                                          PlaceholderText="Search all libraries"
                                          TextChanged="OnSearchTextChanged" />

              <StackPanel Spacing="8">
                <Border x:Name="ThisFileButtonBorder"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="12">
                  <Button Style="{StaticResource ChromeButtonStyle}"
                          HorizontalContentAlignment="Stretch"
                          Padding="12,10"
                          Click="OnThisFileClick">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                      <controls:FigmaIcon Kind="Library"
                                          Width="18"
                                          Height="18"
                                          IconStroke="{StaticResource TextBrush}" />
                      <TextBlock Text="This file"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                    </StackPanel>
                  </Button>
                </Border>

                <Border x:Name="UpdatesButtonBorder"
                        Background="Transparent"
                        CornerRadius="12">
                  <Button Style="{StaticResource ChromeButtonStyle}"
                          HorizontalContentAlignment="Stretch"
                          Padding="12,10"
                          Click="OnUpdatesClick">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                      <controls:FigmaIcon Kind="Refresh"
                                          Width="18"
                                          Height="18"
                                          IconStroke="{StaticResource TextBrush}" />
                      <TextBlock Grid.Column="1"
                                 Text="Updates"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                      <Border Grid.Column="2"
                              x:Name="UpdatesBadge"
                              Background="{StaticResource AccentSoftBrush}"
                              CornerRadius="8"
                              Padding="8,2"
                              Visibility="Collapsed">
                        <TextBlock x:Name="UpdatesBadgeText"
                                   Style="{StaticResource ShellTitleStyle}"
                                   FontSize="11"
                                   Foreground="{StaticResource AccentBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                </Border>
              </StackPanel>

              <Border Height="1"
                      Background="{StaticResource SidebarDividerBrush}" />

              <StackPanel Spacing="10">
                <TextBlock Text="Browse libraries"
                           Style="{StaticResource ShellBodyStyle}"
                           FontSize="12.5" />

                <Border x:Name="TeamsButtonBorder"
                        Background="Transparent"
                        CornerRadius="12">
                  <Button Style="{StaticResource ChromeButtonStyle}"
                          HorizontalContentAlignment="Stretch"
                          Padding="12,10"
                          Click="OnTeamsClick">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                      <controls:FigmaIcon Kind="Team"
                                          Width="18"
                                          Height="18"
                                          IconStroke="{StaticResource TextBrush}" />
                      <TextBlock Text="Teams"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                    </StackPanel>
                  </Button>
                </Border>

                <Border x:Name="UiKitsButtonBorder"
                        Background="Transparent"
                        CornerRadius="12">
                  <Button Style="{StaticResource ChromeButtonStyle}"
                          HorizontalContentAlignment="Stretch"
                          Padding="12,10"
                          Click="OnUiKitsClick">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                      <controls:FigmaIcon Kind="Package"
                                          Width="18"
                                          Height="18"
                                          IconStroke="{StaticResource TextBrush}" />
                      <TextBlock Text="UI kits"
                                 Style="{StaticResource ShellTitleStyle}"
                                 FontSize="13" />
                    </StackPanel>
                  </Button>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>

          <Grid Grid.Column="1"
                Padding="24,20,24,22"
                RowDefinitions="*">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Enabled"
                          HorizontalScrollMode="Disabled"
                          ZoomMode="Disabled">
              <Grid>
                <StackPanel x:Name="ThisFilePanel"
                            Spacing="20">
              <Border Background="#F7F8FA"
                      CornerRadius="18"
                      Padding="18">
                <Grid ColumnDefinitions="48,*"
                      ColumnSpacing="16">
                  <Border Width="48"
                          Height="48"
                          Background="{StaticResource SurfaceBrush}"
                          BorderBrush="{StaticResource SurfaceStrokeBrush}"
                          BorderThickness="1"
                          CornerRadius="12">
                    <controls:FigmaIcon Kind="Library"
                                        Width="20"
                                        Height="20"
                                        IconStroke="{StaticResource TextBrush}" />
                  </Border>

                  <StackPanel Grid.Column="1"
                              MinWidth="0"
                              Spacing="6">
                    <TextBlock x:Name="PublishTitleText"
                               Style="{StaticResource ShellTitleStyle}"
                               FontSize="16"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2" />
                    <TextBlock x:Name="PublishSubtitleText"
                               Style="{StaticResource ShellBodyStyle}"
                               FontSize="12.5"
                               TextWrapping="WrapWholeWords"
                               MaxLines="3" />
                    <Button x:Name="PublishButton"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Padding="14,9"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Foreground="White"
                            CornerRadius="12"
                            FontWeight="SemiBold"
                            Click="OnPublishCurrentFileClick" />
                  </StackPanel>
                </Grid>
              </Border>

              <StackPanel Spacing="12">
                <TextBlock Text="Libraries added to this file"
                           Style="{StaticResource ShellTitleStyle}"
                           FontSize="15" />

                <ItemsControl x:Name="EnabledLibrariesList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:EditorLibraryItem">
                      <Border Background="{StaticResource SurfaceBrush}"
                              BorderBrush="{StaticResource SurfaceStrokeBrush}"
                              BorderThickness="1"
                              CornerRadius="18"
                              Padding="14"
                              Margin="0,0,0,12">
                        <Grid ColumnDefinitions="132,*,Auto"
                              ColumnSpacing="14">
                          <Border Width="132"
                                  Height="84"
                                  CornerRadius="14"
                                  Background="{x:Bind PreviewSecondaryColor, Converter={StaticResource ColorToBrushConverter}}">
                            <Grid Padding="12">
                              <Border Width="62"
                                      Height="30"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      CornerRadius="9"
                                      Background="{x:Bind PreviewPrimaryColor, Converter={StaticResource ColorToBrushConverter}}" />
                              <Border Width="52"
                                      Height="22"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Bottom"
                                      CornerRadius="8"
                                      Background="{x:Bind PreviewAccentColor, Converter={StaticResource ColorToBrushConverter}}" />
                              <TextBlock Text="{x:Bind PreviewLabel}"
                                         Margin="8,8,8,0"
                                         Foreground="White"
                                         FontWeight="Bold"
                                         FontSize="12"
                                         TextWrapping="WrapWholeWords"
                                         MaxLines="2" />
                            </Grid>
                          </Border>

                          <StackPanel Grid.Column="1"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      Spacing="4">
                            <TextBlock Text="{x:Bind Name}"
                                       Style="{StaticResource ShellTitleStyle}"
                                       FontSize="15"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                            <TextBlock Text="{x:Bind Publisher}"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="12.5"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                            <TextBlock Text="{x:Bind StatusLabel}"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="12"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="2" />
                            <TextBlock Text="{x:Bind AssetsCountLabel}"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11.5"
                                       Foreground="{StaticResource MutedTextBrush}" />
                          </StackPanel>

                          <StackPanel Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Spacing="8">
                            <Button Content="Remove"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    BorderBrush="{StaticResource SurfaceStrokeBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource SurfaceBrush}"
                                    Padding="14,9"
                                    Click="OnLibraryToggleClick" />
                            <Button Content="Update"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    BorderBrush="{StaticResource SurfaceStrokeBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    Padding="14,9"
                                    Visibility="{x:Bind UpdateVisibility, Mode=OneWay}"
                                    Click="OnLibraryUpdateClick" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              <TextBlock x:Name="EnabledLibrariesEmptyState"
                         Text="No libraries are connected to this file yet."
                         Style="{StaticResource ShellBodyStyle}"
                         FontSize="13"
                         Visibility="Collapsed" />

                <Button x:Name="MissingLibrariesButton"
                        Content="View missing libraries"
                        Style="{StaticResource ChromeButtonStyle}"
                        BorderBrush="{StaticResource SurfaceStrokeBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="16,10"
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed"
                        Click="OnMissingLibrariesClick" />
              </StackPanel>
                </StackPanel>

                <StackPanel x:Name="UpdatesPanel"
                            Visibility="Collapsed"
                            Spacing="16">
              <TextBlock Text="Updates"
                         Style="{StaticResource ShellTitleStyle}"
                         FontSize="16" />
              <TextBlock Text="When a shared library ships a new version, update the imported components and swatches here."
                         Style="{StaticResource ShellBodyStyle}"
                         FontSize="12.5"
                         TextWrapping="WrapWholeWords" />

              <ItemsControl x:Name="UpdatesLibrariesList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:EditorLibraryItem">
                      <Border Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource SurfaceStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                        <StackPanel Spacing="4"
                                    MinWidth="0">
                          <TextBlock Text="{x:Bind Name}"
                                     Style="{StaticResource ShellTitleStyle}"
                                     FontSize="15"
                                     TextTrimming="CharacterEllipsis"
                                     MaxLines="1" />
                          <TextBlock Text="{x:Bind StatusLabel}"
                                     Style="{StaticResource ShellBodyStyle}"
                                     FontSize="12.5" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Update"
                                Background="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                Foreground="White"
                                CornerRadius="12"
                                Padding="14,9"
                                Click="OnLibraryUpdateClick" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock x:Name="UpdatesEmptyState"
                         Text="All connected libraries are already up to date."
                         Style="{StaticResource ShellBodyStyle}"
                         FontSize="13"
                         Visibility="Collapsed" />
                </StackPanel>

                <StackPanel x:Name="BrowsePanel"
                            Visibility="Collapsed"
                            Spacing="16">
              <TextBlock x:Name="BrowseTitleText"
                         Style="{StaticResource ShellTitleStyle}"
                         FontSize="16" />
              <TextBlock x:Name="BrowseSubtitleText"
                         Style="{StaticResource ShellBodyStyle}"
                         FontSize="12.5"
                         TextWrapping="WrapWholeWords" />

              <ItemsControl x:Name="BrowseLibrariesList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:EditorLibraryItem">
                      <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource SurfaceStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14"
                            Margin="0,0,0,12">
                      <Grid ColumnDefinitions="132,*,Auto"
                            ColumnSpacing="14">
                        <Border Width="132"
                                Height="84"
                                CornerRadius="14"
                                Background="{x:Bind PreviewSecondaryColor, Converter={StaticResource ColorToBrushConverter}}">
                          <Grid Padding="12">
                            <Border Width="62"
                                    Height="28"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    CornerRadius="9"
                                    Background="{x:Bind PreviewPrimaryColor, Converter={StaticResource ColorToBrushConverter}}" />
                            <Border Width="52"
                                    Height="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="8"
                                    Background="{x:Bind PreviewAccentColor, Converter={StaticResource ColorToBrushConverter}}" />
                            <TextBlock Text="{x:Bind PreviewLabel}"
                                       Margin="8,8,8,0"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="2" />
                          </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    MinWidth="0"
                                    VerticalAlignment="Center"
                                    Spacing="4">
                          <TextBlock Text="{x:Bind Name}"
                                     Style="{StaticResource ShellTitleStyle}"
                                     FontSize="15"
                                     TextTrimming="CharacterEllipsis"
                                     MaxLines="1" />
                          <TextBlock Text="{x:Bind Publisher}"
                                     Style="{StaticResource ShellBodyStyle}"
                                     FontSize="12.5"
                                     TextTrimming="CharacterEllipsis"
                                     MaxLines="1" />
                          <TextBlock Text="{x:Bind Description}"
                                     Style="{StaticResource ShellBodyStyle}"
                                     FontSize="12"
                                     TextWrapping="WrapWholeWords"
                                     MaxLines="2" />
                          <TextBlock Text="{x:Bind AssetsCountLabel}"
                                     Style="{StaticResource ShellBodyStyle}"
                                     FontSize="11.5"
                                     Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="{x:Bind ActionLabel}"
                                Style="{StaticResource ChromeButtonStyle}"
                                BorderBrush="{StaticResource SurfaceStrokeBrush}"
                                BorderThickness="1"
                                Background="{StaticResource SurfaceBrush}"
                                Padding="14,9"
                                Click="OnLibraryToggleClick" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock x:Name="BrowseEmptyState"
                         Text="No libraries match the current search."
                         Style="{StaticResource ShellBodyStyle}"
                         FontSize="13"
                         Visibility="Collapsed" />
                </StackPanel>
              </Grid>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
