<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.SvgEditorTopBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Margin="{StaticResource ShellTopBarMargin}"
        ColumnDefinitions="Auto,*,Auto"
        ColumnSpacing="12">
    <Border Style="{StaticResource TopBarIslandBorderStyle}"
            Padding="10,8">
      <Grid ColumnDefinitions="Auto,Auto,Auto"
            ColumnSpacing="10">
        <Button x:Name="MainMenuButton"
                Style="{StaticResource GhostPillButtonStyle}"
                Padding="12,7"
                MinWidth="88"
                Height="36"
                Click="OnMainMenuClick">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <controls:EditorBrandMark Width="14"
                                      Height="20"
                                      VerticalAlignment="Center" />
            <TextBlock Text="Menu"
                       Style="{StaticResource ShellTitleStyle}"
                       FontSize="12.25"
                       VerticalAlignment="Center" />
            <TextBlock Text="⌄"
                       Style="{StaticResource SectionCaptionStyle}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Grid.Column="1"
                Style="{StaticResource SubtleIconButtonStyle}"
                Width="32"
                Height="32"
                Padding="0"
                Click="OnLeftPanelToggleClick"
                ToolTipService.ToolTip="Toggle left panel">
          <Grid Width="20"
                Height="14">
            <Border Width="7"
                    Height="14"
                    BorderBrush="{StaticResource TextBrush}"
                    BorderThickness="1.1"
                    CornerRadius="2"
                    HorizontalAlignment="Left" />
            <Border Width="11"
                    Height="14"
                    BorderBrush="{StaticResource TextBrush}"
                    BorderThickness="1.1"
                    CornerRadius="2"
                    HorizontalAlignment="Right" />
          </Grid>
        </Button>

        <StackPanel Grid.Column="2"
                    VerticalAlignment="Center"
                    Spacing="2">
          <TextBlock Text="{Binding ViewModel.DocumentTitle, ElementName=Root, Mode=OneWay}"
                     Style="{StaticResource SidebarPrimaryTitleStyle}"
                     FontSize="15.5" />
          <TextBlock Text="{Binding ViewModel.CurrentToolLabel, ElementName=Root, Mode=OneWay}"
                     Style="{StaticResource SectionCaptionStyle}" />
        </StackPanel>
      </Grid>
    </Border>

    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right">
      <Border Style="{StaticResource TopBarIslandBorderStyle}"
              Padding="6">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Button Content="Reset"
                  Style="{StaticResource GhostPillButtonStyle}"
                  Click="OnResetClick" />
          <Button Content="Fit"
                  Style="{StaticResource GhostPillButtonStyle}"
                  Click="OnFitClick" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource TopBarIslandBorderStyle}"
              Padding="6,4">
        <Button x:Name="ZoomMenuButton"
                Style="{StaticResource ChromeButtonStyle}"
                Padding="12,8"
                Click="OnZoomMenuClick">
          <StackPanel Orientation="Horizontal"
                      Spacing="6">
            <TextBlock Text="{Binding ViewModel.ViewportLabel, ElementName=Root, Mode=OneWay}"
                       Style="{StaticResource ShellTitleStyle}"
                       FontSize="12.25" />
            <TextBlock Text="⌄"
                       Style="{StaticResource SectionCaptionStyle}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Border>

      <Border Style="{StaticResource TopBarIslandBorderStyle}"
              Padding="12,8"
              VerticalAlignment="Center">
        <TextBlock Text="{Binding ViewModel.SelectionSummary, ElementName=Root, Mode=OneWay}"
                   Style="{StaticResource SectionCaptionStyle}"
                   FontSize="12" />
      </Border>

      <Border Background="{StaticResource AccentSoftBrush}"
              BorderBrush="{StaticResource AccentStrongBrush}"
              BorderThickness="1"
              CornerRadius="14">
        <Button Style="{StaticResource PlainIconButtonStyle}"
                Padding="16,10"
                MinWidth="84"
                Height="40"
                Click="OnShareClick"
                ToolTipService.ToolTip="Open share and export actions">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <controls:FigmaIcon Kind="Send"
                                Width="14"
                                Height="14"
                                IconStroke="{StaticResource AccentBrush}" />
            <TextBlock Text="Share"
                       Style="{StaticResource ShellTitleStyle}"
                       FontSize="12.25"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
