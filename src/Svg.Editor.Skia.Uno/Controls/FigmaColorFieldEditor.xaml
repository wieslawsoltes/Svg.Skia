<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.FigmaColorFieldEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid ColumnDefinitions="*,Auto,Auto"
        ColumnSpacing="6">
    <Button x:Name="OpenPickerButton"
            Background="{StaticResource PickerChipBrush}"
            BorderBrush="{StaticResource PickerDividerBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="10,8"
            Click="OnOpenPickerClick">
      <Button.Flyout>
        <Flyout x:Name="PickerFlyout"
                Placement="Left">
          <Flyout.FlyoutPresenterStyle>
            <StaticResource ResourceKey="PickerFlyoutPresenterStyle" />
          </Flyout.FlyoutPresenterStyle>
          <controls:FigmaColorPicker x:Name="Picker"
                                     SelectedColor="{Binding SelectedColor, ElementName=Root, Mode=TwoWay}"
                                     Swatches="{Binding Swatches, ElementName=Root, Mode=OneWay}"
                                     LibraryStyles="{Binding LibraryStyles, ElementName=Root, Mode=OneWay}"
                                     PaintTarget="{Binding PaintTarget, ElementName=Root, Mode=OneWay}"
                                     CurrentStrokeWidthText="{Binding CurrentStrokeWidthText, ElementName=Root, Mode=OneWay}" />
        </Flyout>
      </Button.Flyout>
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="10">
        <Border Width="28"
                Height="28"
                Background="{Binding SelectedColor, ElementName=Root, Converter={StaticResource ColorToBrushConverter}}"
                BorderBrush="{StaticResource SurfaceStrokeBrush}"
                BorderThickness="1"
                CornerRadius="7" />
        <TextBlock x:Name="SummaryTextBlock"
                   Grid.Column="1"
                   VerticalAlignment="Center"
                   Style="{StaticResource ShellTitleStyle}"
                   FontSize="13" />
        <TextBlock x:Name="OpacityTextBlock"
                   Grid.Column="2"
                   VerticalAlignment="Center"
                   Style="{StaticResource ShellBodyStyle}"
                   FontSize="12" />
      </Grid>
    </Button>

    <ToggleButton x:Name="VisibilityToggleButton"
                  Grid.Column="1"
                  Background="{StaticResource PickerChipBrush}"
                  BorderBrush="{StaticResource PickerDividerBrush}"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="10,8"
                  Visibility="Visible"
                  Click="OnVisibilityToggleClick">
      <controls:FigmaIcon x:Name="VisibilityIcon"
                          Width="14"
                          Height="14"
                          IconStroke="{StaticResource TextBrush}" />
    </ToggleButton>

    <Button x:Name="ClearButton"
            Grid.Column="2"
            Background="{StaticResource PickerChipBrush}"
            BorderBrush="{StaticResource PickerDividerBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="10,8"
            Visibility="Visible"
            Click="OnClearClick">
      <controls:FigmaIcon x:Name="ActionIcon"
                          Kind="Minus"
                          Width="12"
                          Height="12"
                          IconStroke="{StaticResource TextBrush}" />
    </Button>
  </Grid>
</UserControl>
