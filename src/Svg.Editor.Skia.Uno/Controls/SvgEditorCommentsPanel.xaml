<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.SvgEditorCommentsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    xmlns:models="using:Svg.Editor.Skia.Uno.Models"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="12">
    <Grid ColumnDefinitions="*,Auto"
          ColumnSpacing="8">
      <controls:EditorSearchField x:Name="SearchField"
                                  PlaceholderText="Search comments"
                                  TextChanged="OnSearchTextChanged" />
      <Button Grid.Column="1"
              Style="{StaticResource SubtleIconButtonStyle}"
              Click="OnResolvedToggleClick">
        <controls:FigmaIcon Kind="Adjust"
                            Width="15"
                            Height="15"
                            IconStroke="{StaticResource SidebarIconBrush}" />
      </Button>
    </Grid>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="8">
      <TextBlock Text="{Binding SummaryText, ElementName=Root, Mode=OneWay}"
                 Style="{StaticResource SectionCaptionStyle}"
                 VerticalAlignment="Center" />
      <Border Grid.Column="1"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource SurfaceStrokeBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="10,6">
        <TextBlock x:Name="ResolvedToggleTextBlock"
                   Text="All"
                   Style="{StaticResource ShellTitleStyle}"
                   FontSize="11.5" />
      </Border>
    </Grid>

    <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="10">
        <TextBlock x:Name="EmptyStateTextBlock"
                   Style="{StaticResource SectionCaptionStyle}"
                   Text="No comments on this page yet."
                   Visibility="Collapsed" />

        <ItemsControl ItemsSource="{Binding VisibleThreads, ElementName=Root, Mode=OneWay}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:EditorCommentThread">
              <Border Background="{x:Bind IsSelected, Converter={StaticResource BooleanToBrushConverter}}"
                      BorderBrush="{StaticResource SurfaceStrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="16"
                      Padding="12">
                <StackPanel Spacing="12">
                  <Button HorizontalAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0"
                          Click="OnThreadButtonClick">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="10">
                      <Border Width="34"
                              Height="34"
                              Background="{StaticResource AccentBrush}"
                              CornerRadius="17"
                              VerticalAlignment="Top">
                        <TextBlock Text="{x:Bind MarkerInitials}"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                      </Border>

                      <StackPanel Grid.Column="1"
                                  Spacing="3"
                                  HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                          <TextBlock Text="{x:Bind ThreadLabel}"
                                     Style="{StaticResource ShellTitleStyle}"
                                     FontSize="12.5" />
                          <Border Grid.Column="1"
                                  Background="{StaticResource AccentSoftBrush}"
                                  CornerRadius="8"
                                  Padding="6,2"
                                  Visibility="{x:Bind ResolvedVisibility}">
                            <TextBlock Text="Resolved"
                                       Style="{StaticResource ShellTitleStyle}"
                                       FontSize="10.5"
                                       Foreground="{StaticResource AccentBrush}" />
                          </Border>
                        </Grid>

                        <TextBlock Text="{x:Bind MetaText}"
                                   Style="{StaticResource SectionCaptionStyle}" />
                        <TextBlock Text="{x:Bind TargetLabel}"
                                   Style="{StaticResource SectionCaptionStyle}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind PreviewText}"
                                   Style="{StaticResource ShellBodyStyle}"
                                   TextWrapping="WrapWholeWords" />
                      </StackPanel>
                    </Grid>
                  </Button>

                  <StackPanel Visibility="{x:Bind ExpandedVisibility}"
                              Spacing="10">
                    <ItemsControl ItemsSource="{x:Bind Messages}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:EditorCommentMessage">
                          <Border Background="{StaticResource SurfaceAltBrush}"
                                  BorderBrush="{StaticResource SurfaceStrokeBrush}"
                                  BorderThickness="1"
                                  CornerRadius="12"
                                  Padding="10"
                                  Margin="0,0,0,6">
                            <StackPanel Spacing="4">
                              <Grid ColumnDefinitions="*,Auto"
                                    ColumnSpacing="8">
                                <TextBlock Text="{x:Bind AuthorName}"
                                           Style="{StaticResource ShellTitleStyle}"
                                           FontSize="12" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind TimestampText}"
                                           Style="{StaticResource SectionCaptionStyle}" />
                              </Grid>
                              <TextBlock Text="{x:Bind Text}"
                                         Style="{StaticResource ShellBodyStyle}"
                                         TextWrapping="WrapWholeWords" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBox Text="{x:Bind DraftReplyText, Mode=TwoWay}"
                             Style="{StaticResource ShellTextBoxStyle}"
                             PlaceholderText="Reply to thread" />

                    <Grid ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="8">
                      <Button Style="{StaticResource GhostPillButtonStyle}"
                              Content="{x:Bind ResolveButtonText}"
                              Click="OnResolveButtonClick" />
                      <Button Grid.Column="1"
                              Style="{StaticResource GhostPillButtonStyle}"
                              Content="Delete"
                              Click="OnDeleteButtonClick" />
                      <Border Grid.Column="2"
                              HorizontalAlignment="Right"
                              Background="{StaticResource AccentBrush}"
                              CornerRadius="10">
                        <Button Style="{StaticResource ToolButtonStyle}"
                                Padding="12,8"
                                Click="OnReplyButtonClick">
                          <StackPanel Orientation="Horizontal"
                                      Spacing="6">
                            <controls:FigmaIcon Kind="Send"
                                                Width="13"
                                                Height="13"
                                                IconStroke="White" />
                            <TextBlock Text="Reply"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="11.5" />
                          </StackPanel>
                        </Button>
                      </Border>
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
