<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.FigmaFrameEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Svg.Editor.Skia.Uno.Models"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <StackPanel Spacing="10">
    <Grid x:Name="HeaderGrid"
          ColumnDefinitions="*,Auto">
      <TextBlock Text="Container"
                 Style="{StaticResource ShellTitleStyle}"
                 FontSize="14" />
      <Border Grid.Column="1"
              Background="{StaticResource AccentSoftBrush}"
              CornerRadius="10"
              Padding="10,6">
        <TextBlock Text="{Binding ContainerKind, ElementName=Root, Mode=OneWay}"
                   Style="{StaticResource FieldLabelStyle}" />
      </Border>
    </Grid>

    <TextBlock x:Name="HintTextBlock"
               Style="{StaticResource SectionCaptionStyle}"
               TextWrapping="WrapWholeWords" />

    <StackPanel x:Name="CompactEditorStack"
                Orientation="Horizontal"
                Spacing="10"
                Visibility="Collapsed">
      <ComboBox x:Name="CompactKindComboBox"
                Width="132"
                Style="{StaticResource PickerComboBoxStyle}"
                SelectionChanged="OnCompactKindSelectionChanged">
        <ComboBoxItem Content="Frame" Tag="Frame" />
        <ComboBoxItem Content="Section" Tag="Section" />
        <ComboBoxItem Content="Group" Tag="Group" />
      </ComboBox>

      <ComboBox x:Name="CompactPresetComboBox"
                Width="164"
                Style="{StaticResource PickerComboBoxStyle}"
                ItemsSource="{Binding Presets, ElementName=Root, Mode=OneWay}"
                SelectedValuePath="Id"
                SelectedValue="{Binding SelectedPresetId, ElementName=Root, Mode=TwoWay}"
                SelectionChanged="OnCompactPresetSelectionChanged">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="models:EditorFramePresetItem">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
              <TextBlock Text="{x:Bind Name}"
                         Style="{StaticResource ShellTitleStyle}"
                         FontSize="12.5" />
              <TextBlock Grid.Column="1"
                         Text="{x:Bind SizeLabel}"
                         Style="{StaticResource SectionCaptionStyle}"
                         VerticalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel x:Name="EditorStack"
                Spacing="10">
      <StackPanel Spacing="8">
        <TextBlock Text="Type"
                   Style="{StaticResource InspectorSubLabelStyle}" />
        <ComboBox x:Name="KindComboBox"
                  Style="{StaticResource PickerComboBoxStyle}"
                  SelectionChanged="OnKindSelectionChanged">
          <ComboBoxItem Content="Frame" Tag="Frame" />
          <ComboBoxItem Content="Section" Tag="Section" />
          <ComboBoxItem Content="Group" Tag="Group" />
        </ComboBox>
      </StackPanel>

      <StackPanel x:Name="PresetStack"
                  Spacing="8">
        <TextBlock Text="Preset"
                   Style="{StaticResource InspectorSubLabelStyle}" />
        <ComboBox x:Name="PresetComboBox"
                  Style="{StaticResource PickerComboBoxStyle}"
                  ItemsSource="{Binding Presets, ElementName=Root, Mode=OneWay}"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding SelectedPresetId, ElementName=Root, Mode=TwoWay}"
                  SelectionChanged="OnPresetSelectionChanged">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="models:EditorFramePresetItem">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <StackPanel Spacing="1">
                  <TextBlock Text="{x:Bind Name}"
                             Style="{StaticResource ShellTitleStyle}"
                             FontSize="12.5" />
                  <TextBlock Text="{x:Bind Category}"
                             Style="{StaticResource SectionCaptionStyle}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind SizeLabel}"
                           Style="{StaticResource SectionCaptionStyle}"
                           VerticalAlignment="Center" />
              </Grid>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <Border Style="{StaticResource InsetFrameBorderStyle}"
              x:Name="SummaryBorder"
              Padding="10">
        <TextBlock Text="{Binding SummaryText, ElementName=Root, Mode=OneWay}"
                   Style="{StaticResource SectionCaptionStyle}"
                   TextWrapping="WrapWholeWords" />
      </Border>
    </StackPanel>
  </StackPanel>
</UserControl>
