<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.FigmaEffectsEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    xmlns:models="using:Svg.Editor.Skia.Uno.Models"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <StackPanel Spacing="10">
    <Grid x:Name="HeaderGrid"
          ColumnDefinitions="*,Auto">
      <TextBlock Text="Effects"
                 Style="{StaticResource ShellTitleStyle}"
                 FontSize="14" />
      <Button Grid.Column="1"
              Style="{StaticResource EffectIconButtonStyle}"
              IsEnabled="{Binding IsEditable, ElementName=Root, Mode=OneWay}">
        <Button.Flyout>
          <MenuFlyout>
            <MenuFlyout.MenuFlyoutPresenterStyle>
              <StaticResource ResourceKey="PickerMenuFlyoutPresenterStyle" />
            </MenuFlyout.MenuFlyoutPresenterStyle>
            <MenuFlyoutItem Text="Drop shadow" Tag="DropShadow" Click="OnAddEffectMenuItemClick" />
            <MenuFlyoutItem Text="Inner shadow" Tag="InnerShadow" Click="OnAddEffectMenuItemClick" />
            <MenuFlyoutItem Text="Layer blur" Tag="LayerBlur" Click="OnAddEffectMenuItemClick" />
            <MenuFlyoutItem Text="Background blur" Tag="BackgroundBlur" Click="OnAddEffectMenuItemClick" />
            <MenuFlyoutItem Text="Noise" Tag="Noise" Click="OnAddEffectMenuItemClick" />
            <MenuFlyoutItem Text="Texture" Tag="Texture" Click="OnAddEffectMenuItemClick" />
            <MenuFlyoutItem Text="Glass" Tag="Glass" Click="OnAddEffectMenuItemClick" />
          </MenuFlyout>
        </Button.Flyout>
        <controls:FigmaIcon Kind="Add"
                            Width="13"
                            Height="13"
                            IconStroke="{StaticResource TextBrush}" />
      </Button>
    </Grid>

    <TextBlock x:Name="HintTextBlock"
               Text="Select a single layer to edit filters and generated SVG effect stacks."
               Style="{StaticResource ShellBodyStyle}"
               FontSize="12"
               TextWrapping="WrapWholeWords" />

    <ItemsControl x:Name="EffectsItemsControl"
                  ItemsSource="{Binding ItemsSource, ElementName=Root, Mode=OneWay}">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="models:EditorEffectItem">
          <Grid Margin="0,0,0,8"
                ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8">
            <ToggleButton IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                          Style="{StaticResource EffectToggleButtonStyle}">
              <controls:FigmaIcon Kind="Eye"
                                  Width="13"
                                  Height="13"
                                  IconStroke="{StaticResource AccentBrush}" />
            </ToggleButton>

            <Button Grid.Column="1"
                    Style="{StaticResource EffectRowButtonStyle}">
              <Button.Flyout>
                <Flyout Placement="LeftEdgeAlignedTop">
                  <Flyout.FlyoutPresenterStyle>
                    <StaticResource ResourceKey="PickerFlyoutPresenterStyle" />
                  </Flyout.FlyoutPresenterStyle>
                  <Grid Width="380">
                    <Border Margin="0,8,0,0"
                            Background="{StaticResource PickerShadowBrush}"
                            CornerRadius="26"
                            Opacity="0.36" />
                    <Border Background="{StaticResource PickerSurfaceBrush}"
                            BorderBrush="{StaticResource PickerDividerBrush}"
                            BorderThickness="1"
                            CornerRadius="26">
                      <StackPanel>
                        <Grid Padding="14"
                              ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8">
                          <ComboBox MinWidth="188"
                                    Style="{StaticResource PickerComboBoxStyle}"
                                    Loaded="OnEffectKindComboBoxLoaded"
                                    SelectionChanged="OnEffectKindSelectionChanged">
                            <ComboBoxItem Content="Drop shadow" Tag="DropShadow" />
                            <ComboBoxItem Content="Inner shadow" Tag="InnerShadow" />
                            <ComboBoxItem Content="Layer blur" Tag="LayerBlur" />
                            <ComboBoxItem Content="Background blur" Tag="BackgroundBlur" />
                            <ComboBoxItem Content="Noise" Tag="Noise" />
                            <ComboBoxItem Content="Texture" Tag="Texture" />
                            <ComboBoxItem Content="Glass" Tag="Glass" />
                          </ComboBox>
                          <Button Grid.Column="1"
                                  Style="{StaticResource EffectIconButtonStyle}"
                                  Click="OnMoveUpClick">
                            <TextBlock Text="↑"
                                       Style="{StaticResource ShellTitleStyle}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                          </Button>
                          <Button Grid.Column="2"
                                  Style="{StaticResource EffectIconButtonStyle}"
                                  Click="OnMoveDownClick">
                            <TextBlock Text="↓"
                                       Style="{StaticResource ShellTitleStyle}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                          </Button>
                        </Grid>

                        <Border Height="1"
                                Background="{StaticResource SurfaceStrokeBrush}" />

                        <StackPanel Padding="14"
                                    Spacing="12">
                          <Grid Visibility="{x:Bind PositionVisibility}"
                                ColumnDefinitions="96,*,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Position"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Header="X"
                                     Text="{x:Bind OffsetXText, Mode=TwoWay}" />
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Header="Y"
                                     Text="{x:Bind OffsetYText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind BlurVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Blur"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Text="{x:Bind BlurText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind SpreadVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Spread"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Text="{x:Bind SpreadText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind ScaleVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Scale"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Text="{x:Bind ScaleText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind AmountVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Amount"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Text="{x:Bind AmountText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind DistortionVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Distortion"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Text="{x:Bind DistortionText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind SaturationVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Saturation"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ShellTextBoxStyle}"
                                     Text="{x:Bind SaturationText, Mode=TwoWay}" />
                          </Grid>

                          <Grid Visibility="{x:Bind ColorVisibility}"
                                ColumnDefinitions="96,*"
                                ColumnSpacing="10">
                            <TextBlock Text="Color"
                                       Style="{StaticResource ShellBodyStyle}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <controls:FigmaColorFieldEditor Grid.Column="1"
                                                            SelectedColor="{x:Bind Color, Mode=TwoWay}"
                                                            IsColorEnabled="True"
                                                            IsColorEditable="{Binding IsEditable, ElementName=Root, Mode=OneWay}"
                                                            ShowActions="False"
                                                            SummaryText="{x:Bind Summary, Mode=OneWay}"
                                                            Swatches="{Binding Swatches, ElementName=Root, Mode=OneWay}" />
                          </Grid>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Flyout>
              </Button.Flyout>

              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="8">
                <StackPanel>
                  <TextBlock Text="{x:Bind DisplayName}"
                             Style="{StaticResource ShellTitleStyle}"
                             FontSize="13" />
                  <TextBlock Text="{x:Bind Summary}"
                             Style="{StaticResource ShellBodyStyle}"
                             FontSize="11" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="▾"
                           Style="{StaticResource ShellBodyStyle}"
                           FontSize="12"
                           VerticalAlignment="Center" />
              </Grid>
            </Button>

            <Button Grid.Column="2"
                    Style="{StaticResource EffectIconButtonStyle}"
                    Click="OnRemoveEffectClick">
              <controls:FigmaIcon Kind="Minus"
                                  Width="12"
                                  Height="12"
                                  IconStroke="{StaticResource TextBrush}" />
            </Button>
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </StackPanel>
</UserControl>
