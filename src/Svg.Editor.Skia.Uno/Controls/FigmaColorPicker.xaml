<UserControl
    x:Class="Svg.Editor.Skia.Uno.Controls.FigmaColorPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Svg.Editor.Skia.Uno.Controls"
    xmlns:models="using:Svg.Editor.Skia.Uno.Models"
    x:Name="Root">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Svg.Editor.Skia.Uno/Themes/EditorThemeResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid Width="412">
    <Border Margin="0,6,0,0"
            Background="{StaticResource PickerShadowBrush}"
            CornerRadius="24"
            Opacity="0.28" />

    <Border Background="{StaticResource PickerSurfaceBrush}"
            BorderBrush="{StaticResource PickerDividerBrush}"
            BorderThickness="1"
            CornerRadius="24">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Grid Padding="12,12,12,9"
              ColumnDefinitions="Auto,*,Auto,Auto">
          <Border x:Name="CustomTabBorder"
                  Background="{StaticResource PickerChipBrush}"
                  CornerRadius="13">
            <Button Style="{StaticResource PickerHeaderButtonStyle}"
                    Click="OnCustomTabClick"
                    Content="Custom" />
          </Border>
          <Border x:Name="LibrariesTabBorder"
                  Grid.Column="1"
                  Background="Transparent"
                  CornerRadius="13"
                  Margin="8,0,0,0">
            <Button Style="{StaticResource PickerHeaderButtonStyle}"
                    Click="OnLibrariesTabClick"
                    Content="Libraries" />
          </Border>
          <Button x:Name="AddSwatchButton"
                  Grid.Column="2"
                  Style="{StaticResource PickerIconButtonStyle}"
                  Click="OnAddSwatchClick"
                  Margin="8,0,0,0">
            <controls:FigmaIcon Kind="Add"
                                Width="15"
                                Height="15"
                                IconStroke="{StaticResource TextBrush}" />
          </Button>
          <Button x:Name="ClosePickerButton"
                  Grid.Column="3"
                  Style="{StaticResource PickerIconButtonStyle}"
                  Click="OnCloseClick"
                  Margin="4,0,0,0">
            <controls:FigmaIcon Kind="Close"
                                Width="14"
                                Height="14"
                                IconStroke="{StaticResource TextBrush}" />
          </Button>
        </Grid>

        <Border Grid.Row="1"
                Height="1"
                Background="{StaticResource PickerDividerBrush}" />

        <Grid Grid.Row="2"
              Padding="12,10"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">
          <Border x:Name="SolidModeBorder"
                  Background="{StaticResource PickerChipBrush}"
                  CornerRadius="11">
            <Button Style="{StaticResource PickerIconButtonStyle}">
              <controls:FigmaIcon Kind="SolidPaint"
                                  Width="16"
                                  Height="16"
                                  IconStroke="{StaticResource TextBrush}"
                                  IconFill="{Binding SelectedColor, ElementName=Root, Converter={StaticResource ColorToBrushConverter}}" />
            </Button>
          </Border>

          <Border Grid.Column="1"
                  Background="Transparent"
                  CornerRadius="11"
                  Margin="8,0,0,0"
                  Opacity="0.38">
            <Button Style="{StaticResource PickerIconButtonStyle}"
                    IsEnabled="False">
              <controls:FigmaIcon Kind="GradientLinear"
                                  Width="16"
                                  Height="16"
                                  IconStroke="{StaticResource TextBrush}" />
            </Button>
          </Border>

          <Border Grid.Column="2"
                  Background="Transparent"
                  CornerRadius="11"
                  Margin="8,0,0,0"
                  Opacity="0.38">
            <Button Style="{StaticResource PickerIconButtonStyle}"
                    IsEnabled="False">
              <controls:FigmaIcon Kind="GradientRadial"
                                  Width="16"
                                  Height="16"
                                  IconStroke="{StaticResource TextBrush}" />
            </Button>
          </Border>

          <Border Grid.Column="3"
                  Background="Transparent"
                  CornerRadius="11"
                  Margin="8,0,0,0"
                  Opacity="0.38">
            <Button Style="{StaticResource PickerIconButtonStyle}"
                    IsEnabled="False">
              <controls:FigmaIcon Kind="ImagePaint"
                                  Width="16"
                                  Height="16"
                                  IconStroke="{StaticResource TextBrush}" />
            </Button>
          </Border>

          <Border Grid.Column="4"
                  Background="Transparent"
                  CornerRadius="11"
                  Margin="8,0,0,0"
                  Opacity="0.38">
            <Button Style="{StaticResource PickerIconButtonStyle}"
                    IsEnabled="False">
              <controls:FigmaIcon Kind="VideoPaint"
                                  Width="16"
                                  Height="16"
                                  IconStroke="{StaticResource TextBrush}" />
            </Button>
          </Border>

          <Border Grid.Column="5"
                  Background="Transparent"
                  CornerRadius="11"
                  Margin="8,0,0,0"
                  Opacity="0.38">
            <Button Style="{StaticResource PickerIconButtonStyle}"
                    IsEnabled="False">
              <controls:FigmaIcon Kind="Image"
                                  Width="16"
                                  Height="16"
                                  IconStroke="{StaticResource TextBrush}" />
            </Button>
          </Border>

          <Button Grid.Column="7"
                  Style="{StaticResource PickerIconButtonStyle}"
                  IsEnabled="False"
                  Opacity="0.38">
            <controls:FigmaIcon Kind="Droplet"
                                Width="16"
                                Height="16"
                                IconStroke="{StaticResource TextBrush}" />
          </Button>

          <Button Grid.Column="8"
                  Style="{StaticResource PickerIconButtonStyle}"
                  IsEnabled="False"
                  Opacity="0.38"
                  Margin="4,0,0,0">
            <controls:FigmaIcon Kind="DropletOff"
                                Width="16"
                                Height="16"
                                IconStroke="{StaticResource TextBrush}" />
          </Button>
        </Grid>

        <ScrollViewer Grid.Row="3"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Auto">
          <Grid>
            <StackPanel x:Name="CustomPanel"
                        Padding="12,6,12,12"
                        Spacing="12">
              <controls:FigmaColorSpectrumCanvas x:Name="SpectrumCanvas"
                                                 Height="308"
                                                 MinWidth="0" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <Button Style="{StaticResource PickerIconButtonStyle}"
                        IsEnabled="False"
                        Opacity="0.38"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Center">
                  <controls:FigmaIcon Kind="Droplet"
                                      Width="16"
                                      Height="16"
                                      IconStroke="{StaticResource TextBrush}" />
                </Button>
                <StackPanel Grid.Column="1"
                            Spacing="10">
                  <controls:FigmaHueSliderCanvas x:Name="HueSlider"
                                                 Height="30" />
                  <controls:FigmaAlphaSliderCanvas x:Name="AlphaSlider"
                                                   Height="30" />
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="106,*"
                    ColumnSpacing="12">
                <ComboBox x:Name="FormatComboBox"
                          Style="{StaticResource PickerComboBoxStyle}"
                          SelectionChanged="OnFormatSelectionChanged">
                  <ComboBoxItem Content="RGB" Tag="Rgb" />
                  <ComboBoxItem Content="HSL" Tag="Hsl" />
                  <ComboBoxItem Content="HEX" Tag="Hex" />
                </ComboBox>

                <Grid Grid.Column="1">
                  <Border x:Name="NumericFieldsBorder"
                          Background="{StaticResource PickerSectionBrush}"
                          BorderBrush="{StaticResource PickerDividerBrush}"
                          BorderThickness="1"
                          CornerRadius="12">
                    <Grid ColumnDefinitions="*,*,*,*,Auto">
                      <TextBox x:Name="Channel1TextBox"
                               Style="{StaticResource PickerInlineTextBoxStyle}"
                               KeyDown="OnChannelKeyDown"
                               LostFocus="OnChannelLostFocus" />
                      <TextBox x:Name="Channel2TextBox"
                               Grid.Column="1"
                               Style="{StaticResource PickerInlineTextBoxStyle}"
                               KeyDown="OnChannelKeyDown"
                               LostFocus="OnChannelLostFocus" />
                      <TextBox x:Name="Channel3TextBox"
                               Grid.Column="2"
                               Style="{StaticResource PickerInlineTextBoxStyle}"
                               KeyDown="OnChannelKeyDown"
                               LostFocus="OnChannelLostFocus" />
                      <TextBox x:Name="AlphaPercentTextBox"
                               Grid.Column="3"
                               Style="{StaticResource PickerInlineTextBoxStyle}"
                               KeyDown="OnChannelKeyDown"
                               LostFocus="OnChannelLostFocus" />
                      <Border Grid.Column="1"
                              Width="1"
                              HorizontalAlignment="Left"
                              Background="{StaticResource PickerDividerBrush}" />
                      <Border Grid.Column="2"
                              Width="1"
                              HorizontalAlignment="Left"
                              Background="{StaticResource PickerDividerBrush}" />
                      <Border Grid.Column="3"
                              Width="1"
                              HorizontalAlignment="Left"
                              Background="{StaticResource PickerDividerBrush}" />
                      <Border Grid.Column="4"
                              Width="1"
                              HorizontalAlignment="Left"
                              Background="{StaticResource PickerDividerBrush}" />
                      <TextBlock Grid.Column="4"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"
                                 Text="%"
                                 Style="{StaticResource ShellBodyStyle}" />
                    </Grid>
                  </Border>

                  <Border x:Name="HexFieldsBorder"
                          Background="{StaticResource PickerSectionBrush}"
                          BorderBrush="{StaticResource PickerDividerBrush}"
                          BorderThickness="1"
                          CornerRadius="12"
                          Visibility="Collapsed">
                    <Grid ColumnDefinitions="*,88,Auto">
                      <TextBox x:Name="HexTextBox"
                               Style="{StaticResource PickerInlineTextBoxStyle}"
                               PlaceholderText="RRGGBB"
                               KeyDown="OnHexKeyDown"
                               LostFocus="OnHexLostFocus" />
                      <TextBox x:Name="HexAlphaPercentTextBox"
                               Grid.Column="1"
                               Style="{StaticResource PickerInlineTextBoxStyle}"
                               KeyDown="OnHexKeyDown"
                               LostFocus="OnHexLostFocus" />
                      <Border Grid.Column="1"
                              Width="1"
                              HorizontalAlignment="Left"
                              Background="{StaticResource PickerDividerBrush}" />
                      <Border Grid.Column="2"
                              Width="1"
                              HorizontalAlignment="Left"
                              Background="{StaticResource PickerDividerBrush}" />
                      <TextBlock Grid.Column="2"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"
                                 Text="%"
                                 Style="{StaticResource ShellBodyStyle}" />
                    </Grid>
                  </Border>
                </Grid>
              </Grid>

              <Border Height="1"
                      Background="{StaticResource PickerDividerBrush}" />

              <StackPanel Spacing="12">
                <ComboBox x:Name="PaletteSourceComboBox"
                          Style="{StaticResource PickerComboBoxStyle}"
                          HorizontalAlignment="Stretch">
                  <ComboBoxItem Content="On this page" />
                </ComboBox>

                <GridView x:Name="SwatchGrid"
                          IsItemClickEnabled="True"
                          ItemClick="OnSwatchItemClick"
                          SelectionMode="None"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          BorderThickness="0"
                          Padding="0">
                  <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                      <Setter Property="Margin" Value="0,0,10,10" />
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="BorderThickness" Value="0" />
                      <Setter Property="Background" Value="Transparent" />
                    </Style>
                  </GridView.ItemContainerStyle>
                  <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:ColorSwatchItem">
                      <Border Width="32"
                              Height="32"
                              Background="{Binding Color, Converter={StaticResource ColorToBrushConverter}}"
                              BorderBrush="{StaticResource SurfaceStrokeBrush}"
                              BorderThickness="1"
                              CornerRadius="9" />
                    </DataTemplate>
                  </GridView.ItemTemplate>
                </GridView>
              </StackPanel>
            </StackPanel>

            <StackPanel x:Name="LibrariesPanel"
                        Padding="14,14,14,14"
                        Spacing="14"
                        Visibility="Collapsed">
              <controls:EditorSearchField x:Name="LibrarySearchTextBox"
                                          PlaceholderText="Search"
                                          TextChanged="OnLibrarySearchTextChanged" />

              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <ComboBox x:Name="LibrariesSourceComboBox"
                          Style="{StaticResource PickerComboBoxStyle}"
                          SelectionChanged="OnLibrarySourceSelectionChanged" />
                <Button Grid.Column="1"
                        Style="{StaticResource PickerIconButtonStyle}">
                  <controls:FigmaIcon Kind="Group"
                                      Width="16"
                                      Height="16"
                                      IconStroke="{StaticResource TextBrush}" />
                </Button>
              </Grid>

              <ListView x:Name="LibrariesStylesListView"
                        IsItemClickEnabled="True"
                        ItemClick="OnLibraryStyleItemClick"
                        SelectionMode="None"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                        BorderThickness="0"
                        Background="Transparent">
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:ColorSwatchItem">
                    <Border Background="{StaticResource PickerSectionBrush}"
                            BorderBrush="{StaticResource PickerDividerBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,9">
                      <Grid ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="10">
                        <Grid Width="30"
                              Height="30"
                              VerticalAlignment="Center">
                          <Border Background="{Binding Color, Converter={StaticResource ColorToBrushConverter}}"
                                  BorderBrush="{StaticResource SurfaceStrokeBrush}"
                                  BorderThickness="1"
                                  CornerRadius="8" />
                          <Border Background="Transparent"
                                  BorderBrush="{Binding Color, Converter={StaticResource ColorToBrushConverter}}"
                                  BorderThickness="{x:Bind StrokePreviewThickness, Mode=OneWay}"
                                  CornerRadius="8"
                                  Visibility="{x:Bind StrokePreviewVisibility, Mode=OneWay}" />
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                          <TextBlock Text="{x:Bind Label}"
                                     Style="{StaticResource ShellTitleStyle}"
                                     FontSize="13" />
                          <TextBlock Text="{x:Bind LibrarySummary}"
                                     Style="{StaticResource SectionCaptionStyle}"
                                     FontSize="11.5"
                                     TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                          <TextBlock Text="{x:Bind StyleSummary}"
                                     Style="{StaticResource ShellBodyStyle}"
                                     FontSize="11.5"
                                     HorizontalAlignment="Right" />
                          <TextBlock Text="{x:Bind OpacityLabel}"
                                     Style="{StaticResource SectionCaptionStyle}"
                                     FontSize="11"
                                     HorizontalAlignment="Right" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>

              <TextBlock x:Name="LibrariesEmptyStateText"
                         Text="No paint styles match the current filter."
                         Style="{StaticResource SectionCaptionStyle}"
                         Visibility="Collapsed"
                         TextWrapping="WrapWholeWords" />
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>
